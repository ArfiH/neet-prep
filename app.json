{
  "expo": {
    "name": "neet-zyme",
    "slug": "neet-zyme",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "myapp"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.ahmad.neetzyme",
      "versionCode": 1,
      "icon": "./assets/images/icon.png",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "myapp"
            }
          ],
          "category": [
            "BROWSER",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 120,
          "resizeMode": "contain"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-web-browser",
[
        "react-native-google-mobile-ads",
        {
          "android_app_id": "ca-app-pub-1317710744152870~2156531294",
          "ios_app_id": "ca-app-pub-1317710744152870~2156531294",
          "androidAppId": "ca-app-pub-1317710744152870~2156531294",
          "iosAppId": "ca-app-pub-1317710744152870~2156531294"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "270882ba-0b4f-46a6-95f7-85f9106fa12f"
      }
    }
  }
}
